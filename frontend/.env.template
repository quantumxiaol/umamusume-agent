# 后端 API 基础 URL
# 复制此文件为 .env 并根据需要修改配置
# 命令: cp .env.template .env
VITE_API_BASE_URL=http://127.0.0.1:1111

# 可选：发送给后端的 X-API-Key
# 注意：GitHub Pages 是纯前端，这个值会出现在构建产物里，只能作为轻量门槛
VITE_API_ACCESS_KEY=

# 本地开发默认保留 TTS；GitHub Pages 生产构建会在 workflow 中显式关闭
VITE_ENABLE_TTS=true

# Vite 静态资源基础路径
# 本地开发保持 "/"；GitHub Pages 项目页可设为 "/umamusume-agent/"
VITE_BASE_PATH=/
