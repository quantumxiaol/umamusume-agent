## LLM Settings
## support openai and dashscope(qwen)

# ROLEPLAY_LLM_MODEL_NAME=qwen-long-latest
# ROLEPLAY_LLM_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

ROLEPLAY_LLM_MODEL_NAME=<YOUR_MODEL_NAME_HERE>
ROLEPLAY_LLM_MODEL_BASE_URL=<YOUR_BASE_URL_HERE>
ROLEPLAY_LLM_MODEL_API_KEY=<YOUR_API_KEY_HERE>

# 可选：轻量 API 门槛。若设置，客户端需发送 X-API-Key。
# 注意：如果前端部署在 GitHub Pages，前端中的 key 并不保密。
API_ACCESS_KEY=

# 简单限流（按 IP + 时间窗口，内存级）
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=60
API_CHAT_RATE_LIMIT_MAX_REQUESTS=12

USER_AGENT=MyApp/1.0

## Proxy Settings

# 10808 7890 1080 is normal port

## Dialogue Session Settings
# 会话空闲超时时间（秒）。<=0 表示不启用 TTL
DIALOGUE_SESSION_TTL_SECONDS=36000
# 单个会话最多保留的历史消息条数（user/assistant 消息都算）。<=0 表示不裁剪
DIALOGUE_SESSION_HISTORY_MAX_MESSAGES=40
# 后台清理过期会话的扫描间隔（秒）
DIALOGUE_SESSION_CLEANUP_INTERVAL_SECONDS=60
# 对话历史落盘目录（jsonl）
DIALOGUE_HISTORY_DIRECTORY=./outputs/dialogues
# 是否启用前缀缓存注入（Qwen/百炼兼容）
DIALOGUE_PREFIX_CACHE_ENABLED=true
# 仅当 system prompt 字符数达到阈值时才注入 cache_control
DIALOGUE_PREFIX_CACHE_MIN_CHARS=1000
