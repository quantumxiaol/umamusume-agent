## LLM Settings
## support openai and dashscope(qwen)

# ROLEPLAY_LLM_MODEL_NAME=qwen-long-latest
# ROLEPLAY_LLM_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

ROLEPLAY_LLM_MODEL_NAME=<YOUR_MODEL_NAME_HERE>
ROLEPLAY_LLM_MODEL_BASE_URL=<YOUR_BASE_URL_HERE>
ROLEPLAY_LLM_MODEL_API_KEY=<YOUR_API_KEY_HERE>
ROLEPLAY_LLM_TIMEOUT_SECONDS=60
ROLEPLAY_LLM_MAX_RETRIES=2

# LLM JSON 回复协议
# auto: 优先尝试 response_format=json_object，不支持时自动降级为 prompt-only JSON
# response_format: 强制发送 response_format=json_object
# prompt_only: 不发送 response_format，只靠 prompt 约束 JSON
# disabled: 退回旧“动作：/对白：”两行协议
LLM_JSON_ENABLED=true
LLM_JSON_OUTPUT_MODE=auto
LLM_JSON_RETRY_WITHOUT_RESPONSE_FORMAT_ON_ERROR=true
LLM_JSON_PARSE_LOOSE_JSON=true
LLM_JSON_MAX_RETRIES=1
LLM_JSON_REGENERATE_ON_PARSE_FAILURE=true
LLM_JSON_MAX_REGENERATE_ATTEMPTS=1
LLM_JSON_TEMPERATURE=0.35
LLM_JSON_MAX_TOKENS=320

# 可选：轻量 API 门槛。若设置，客户端需发送 X-API-Key。
# 注意：如果前端部署在 GitHub Pages，前端中的 key 并不保密。
API_ACCESS_KEY=

# 简单限流（按 IP + 时间窗口，内存级）
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=60
API_CHAT_RATE_LIMIT_MAX_REQUESTS=12

# 当前部署默认关闭 TTS
ENABLE_TTS=false

## Dialogue Session Settings
# 会话空闲超时时间（秒）。<=0 表示不启用 TTL
DIALOGUE_SESSION_TTL_SECONDS=36000
# 单个会话最多保留的历史消息条数（user/assistant 消息都算）。<=0 表示不裁剪。
# DeepSeek 会自动做上下文缓存，建议保持不裁剪以提高前缀缓存命中。
DIALOGUE_SESSION_HISTORY_MAX_MESSAGES=0
# 后台清理过期会话的扫描间隔（秒）
DIALOGUE_SESSION_CLEANUP_INTERVAL_SECONDS=60
# 对话历史落盘目录（jsonl）
DIALOGUE_HISTORY_DIRECTORY=./outputs/dialogues
# 是否启用前缀缓存注入（Qwen/百炼兼容）
DIALOGUE_PREFIX_CACHE_ENABLED=true
# 仅当 system prompt 字符数达到阈值时才注入 cache_control
DIALOGUE_PREFIX_CACHE_MIN_CHARS=1000
# 后端隐藏格式约束再注入。只影响发给 LLM 的 messages，不写入历史、不导出到前端。
DIALOGUE_HIDDEN_FORMAT_REINJECTION_ENABLED=true
DIALOGUE_HIDDEN_FORMAT_REINJECTION_INTERVAL_MESSAGES=100

# 导演模式：场景参与者、每轮角色回复数量与导演 JSON 输出上限
DIRECTOR_MAX_PARTICIPANTS=3
DIRECTOR_MAX_SPEAKERS_PER_TURN=2
DIRECTOR_LLM_TEMPERATURE=0.2
DIRECTOR_LLM_MAX_TOKENS=600
DIRECTOR_JSON_REPAIR_ATTEMPTS=1
# 按每个角色自己的回复次数重新注入多人场景约束
DIRECTOR_ROLE_REINJECTION_INTERVAL_REPLIES=25
DIRECTOR_SESSION_TTL_SECONDS=3600
SCENE_TEMPLATES_DIRECTORY=./scenes
# 后端 JSONL 快速恢复副本；无持久盘时仍可由浏览器完整快照恢复
DIRECTOR_HISTORY_DIRECTORY=./outputs/director
